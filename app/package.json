{
  "name": "app",
  "version": "1.1.3",
  "description": "Photograph a Czech store receipt and file it as an expense in Fakturoid",
  "author": "kubiq",
  "main": "index.ts",
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "expo": "^54",
    "expo-constants": "~18.0.13",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.23",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-secure-store": "~15.0.8",
    "expo-share-intent": "^5",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.18",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "typescript": "~5.9.2"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "web:export": "expo export -p web",
    "electron": "electron electron/main.cjs",
    "electron:dev": "expo export -p web && electron electron/main.cjs",
    "electron:build": "expo export -p web && electron-builder",
    "bump": "node scripts/bump.mjs",
    "sync-version": "node scripts/sync-version.mjs",
    "prepare": "git config core.hooksPath app/.husky || true"
  },
  "private": true
