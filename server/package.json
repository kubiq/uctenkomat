{
  "name": "invoice-extractor-server",
  "version": "0.1.0",
  "description": "API: parse store receipts (uctenky) into line items and create expenses in Fakturoid",
  "license": "ISC",
  "type": "module",
  "main": "src/server.mjs",
  "scripts": {
    "start": "node --env-file-if-exists=.env src/server.mjs",
    "dev": "node --env-file-if-exists=.env --watch src/server.mjs",
    "test:api": "node --env-file=.env scripts/test-api.mjs",
    "test:chain": "node --env-file=.env scripts/test-chain.mjs",
    "extract": "node --env-file=.env src/extract.mjs",
    "expense": "node --env-file=.env src/index.mjs",
    "check": "node src/check.mjs"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.2.0",
    "@ai-sdk/openai": "^1.3.22",
    "ai": "^4.3.16",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "multer": "^2.0.1",
    "zod": "^3.25.20"
  }
}
