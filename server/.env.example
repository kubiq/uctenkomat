# --- API server ---
PORT=3000
# Shared secret the mobile app sends as `Authorization: Bearer <APP_API_KEY>`.
# Generate one: `openssl rand -hex 32`
APP_API_KEY=change-me-to-a-long-random-string

# --- Extraction (vision LLM via Vercel AI SDK) ---
# vendor: anthropic | openai
#   anthropic = handles BOTH images and PDFs natively
#   openai    = gpt-4o, images only (fine for phone photos)
EXTRACTOR_VENDOR=openai
# Optional model override. Defaults: claude-3-5-sonnet-latest / gpt-4o
EXTRACTOR_MODEL=
EXTRACTOR_API_KEY=sk-your-key

# --- Fakturoid ---
# OAuth app credentials from Fakturoid: Nastaveni -> API / Propojeni aplikaci
FAKTUROID_CLIENT_ID=
FAKTUROID_CLIENT_SECRET=
FAKTUROID_ACCOUNT_SLUG=your-account-slug
# REQUIRED by Fakturoid on every request, format: "AppName (email@example.com)"
FAKTUROID_USER_AGENT=invoice-extractor (ctverec@proton.me)
# Default flat VAT rate for lines (we don't extract VAT). The app can override per receipt.
# The supplier is resolved automatically from the receipt's IČO — no subject id needed.
FAKTUROID_VAT_RATE=21
